    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ActionType -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ActionType">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ClassificationEntity"/>
        <rdfs:comment>Action type registration</rdfs:comment>
        <rdfs:label>Action type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#AdministrativeEntity -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#AdministrativeEntity"/>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ClassificationEntity -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ClassificationEntity"/>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#CompetentAuthority -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#CompetentAuthority">

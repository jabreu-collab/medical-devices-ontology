<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13/"
     xml:base="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:untitled-ontology-13="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13">
        <rdfs:comment>Se procede a transformar las clases, propiedades de objeto, propiedades de datos, restricciones e instancias desarrollada en el apartado anterior. La implementación sigue los requisitos establecidos en la práctica, utilizando exclusivamente vocabulario en inglés y anotando todos los recursos mediante rdfs:label y rdfs:comment.</rdfs:comment>
        <rdfs:label>European Medical Devices Vigilance And Control Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#affectsDevice -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#affectsDevice">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#MedicalDevice"/>
        <rdfs:comment>Relates an incident to the medical device.</rdfs:comment>
        <rdfs:label>affects devices</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#affectsDeviceType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#affectsDeviceType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#DeviceType"/>
        <rdfs:comment>Relates a risk to the type of devices that can be affected by it.</rdfs:comment>
        <rdfs:label>affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#deviceHasAssociatedRisk -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#deviceHasAssociatedRisk">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Risk"/>
        <rdfs:comment>New Objecte create to resolve SRWL rules.</rdfs:comment>
        <rdfs:label>device has associated risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasActionType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasActionType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCA"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ActionType"/>
        <rdfs:comment>Relates a field safety corrective action to its action type.</rdfs:comment>
        <rdfs:label>has action type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasDeviceType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasDeviceType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#DeviceType"/>
        <rdfs:comment>Relates a medical device to device type classification.</rdfs:comment>
        <rdfs:label>has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasIncidentType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasIncidentType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#IncidentType"/>
        <rdfs:comment>Relates if an incident has a incident type.</rdfs:comment>
        <rdfs:label>has incident type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasManufacturer -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Manufacturer"/>
        <rdfs:comment>Relates a medical device to its manufacturer.</rdfs:comment>
        <rdfs:label>has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasOutcomeType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasOutcomeType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#OutcomeType"/>
        <rdfs:comment>Relates an incident to the outcome classification associated with it.</rdfs:comment>
        <rdfs:label>has outcome type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasPatientSex -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasPatientSex">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#PatientSex"/>
        <rdfs:comment>Relates an incident to the sex category of the affected patient.</rdfs:comment>
        <rdfs:label>has patient sex</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasProbabilityLevel -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasProbabilityLevel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ProbabilityLevel"/>
        <rdfs:comment>Relates a risk to its probability level.</rdfs:comment>
        <rdfs:label>has probability level</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasRisk -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasRisk">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Risk"/>
        <rdfs:comment>Relates an incident to the risk associated.</rdfs:comment>
        <rdfs:label>has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasRiskCategory -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasRiskCategory">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#RiskCategory"/>
        <rdfs:comment>Relates a risk to its risk category classification.</rdfs:comment>
        <rdfs:label>has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasRiskClass -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasRiskClass">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#RiskClass"/>
        <rdfs:comment>Relates a medical device to risk class.</rdfs:comment>
        <rdfs:label>has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasRiskType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasRiskType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#RiskType"/>
        <rdfs:comment>Relates a risk to its risk type classification.</rdfs:comment>
        <rdfs:label>has risk type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasScope -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasScope">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCA"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCAScope"/>
        <rdfs:comment>Relates a field safety corrective action to its scope.</rdfs:comment>
        <rdfs:label>has scope</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasSeverityLevel -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasSeverityLevel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#SeverityLevel"/>
        <rdfs:comment>Relates a risk to its severity level.</rdfs:comment>
        <rdfs:label>has severity level</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasStatus -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCA"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCAStatus"/>
        <rdfs:comment>Relates a field safety corrective action to its current status.</rdfs:comment>
        <rdfs:label>has status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#locatedInCountry -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#locatedInCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Country"/>
        <rdfs:comment>Relates a manufacturer to the country where it is located.</rdfs:comment>
        <rdfs:label>located in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#manufacturerReportedRisk -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#manufacturerReportedRisk">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Risk"/>
        <rdfs:comment>New Objecte create to resolve SRWL rules.</rdfs:comment>
        <rdfs:label>manufacturer reported risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#registeredWithAuthority -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#registeredWithAuthority">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#CompetentAuthority"/>
        <rdfs:comment>Relates a manufacturer to the competent authority with which it is registered.</rdfs:comment>
        <rdfs:label>registered with authority</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#regulatedUnder -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#regulatedUnder">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#RegulatoryFramework"/>
        <rdfs:comment>Relates a medical devices to regulatory framework</rdfs:comment>
        <rdfs:label>regulated under</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#relatesToIncident -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#relatesToIncident">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCA"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
        <rdfs:comment>Relates to incident of FSCA</rdfs:comment>
        <rdfs:label>relates to incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#reportedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#reportedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Manufacturer"/>
        <rdfs:comment>Relates a inicident to manufacturer.</rdfs:comment>
        <rdfs:label>reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#reportedInCountry -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#reportedInCountry">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Country"/>
        <rdfs:comment>Relates a incident to the country where it was reported.</rdfs:comment>
        <rdfs:label>reported in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#targetDevice -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#targetDevice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCA"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#MedicalDevice"/>
        <rdfs:comment>New Objecte create to resolve SRWL rules.</rdfs:comment>
        <rdfs:label>target device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasActionDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasActionDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Stores the date on which a field safety corrective action was initiated.</rdfs:comment>
        <rdfs:label>has action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasAuthorizationNumber -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasAuthorizationNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Stores the authorization number of a manufacturer.</rdfs:comment>
        <rdfs:label>has authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasClosureDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasClosureDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Stores the closure date of a field safety corrective action.</rdfs:comment>
        <rdfs:label>has closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasContactEmail -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasContactEmail">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Stores email of a manufacturer.</rdfs:comment>
        <rdfs:label>has contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasCorrectiveActionTaken -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#hasCorrectiveActionTaken">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether a corrective action has already been taken for an incident.</rdfs:comment>
        <rdfs:label>has corrective action taken</rdfs:label>

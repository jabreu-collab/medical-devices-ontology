        <rdfs:comment>Competent authority registration</rdfs:comment>
        <rdfs:label>Competent authority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Country -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Country">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#AdministrativeEntity"/>
        <rdfs:comment>Country registration</rdfs:comment>
        <rdfs:label>Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#DeviceType -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#DeviceType">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ClassificationEntity"/>
        <rdfs:comment>Device type registration</rdfs:comment>
        <rdfs:label>Device type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCA -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCA">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#relatesToIncident"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>FSCA registration</rdfs:comment>
        <rdfs:label>FSCA</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCAScope -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCAScope">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ClassificationEntity"/>
        <rdfs:comment>FSCA scope registration</rdfs:comment>
        <rdfs:label>FSCA scope</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCAStatus -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#FSCAStatus">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#ClassificationEntity"/>
        <rdfs:comment>FSCA status registration</rdfs:comment>
        <rdfs:label>FSCA status</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident -->

    <owl:Class rdf:about="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#Incident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/posy/ontologies/2026/2/untitled-ontology-13#affectsDevice"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
